# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/iyawe?retryWrites=true&w=majority"

# Auth
JWT_SECRET="your-secret-key-change-in-production"

# Server (Render sets PORT automatically)
PORT=5000
NODE_ENV=production

# CORS — your frontend URL(s), comma-separated
CORS_ORIGIN="https://your-app.vercel.app"

# Public site URL (used in email links and buttons)
APP_URL="https://your-app.vercel.app"

# Email (Gmail: use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Subizwa <your-email@gmail.com>
SMTP_TIMEOUT_MS=15000

# Optional: where admin match alerts are sent (defaults to SMTP_USER)
# ADMIN_ALERT_EMAIL=admin@example.com
