# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/iyawe?retryWrites=true&w=majority"

# Auth
JWT_SECRET="your-secret-key-change-in-production"

# Server (Render sets PORT automatically)
PORT=5000
NODE_ENV=production

# CORS — your frontend URL(s), comma-separated
CORS_ORIGIN="https://your-app.vercel.app"

# Public site URL (used in email links and buttons)
APP_URL="https://your-app.vercel.app"

# ── Email on Render (recommended) ─────────────────────────────────────────────
# Render blocks SMTP ports 587/465. Use Resend HTTPS API instead:
# 1. Sign up at https://resend.com
# 2. Create an API key
# 3. Verify your domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Subizwa <noreply@yourdomain.com>

# ── Email for local development (optional) ───────────────────────────────────
# Gmail SMTP works locally but NOT on Render free tier.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Subizwa <your-email@gmail.com>
EMAIL_TIMEOUT_MS=15000

# Optional: where admin match alerts are sent (defaults to SMTP_USER)
# ADMIN_ALERT_EMAIL=admin@example.com
